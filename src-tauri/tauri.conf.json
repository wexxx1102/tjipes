{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "天津知识产权交易中心触摸屏展示软件",
  "version": "1.0.0",
  "identifier": "com.tjipe.touchscreen",
  "build": {
    "beforeDevCommand": "npm run sync:web-dist",
    "beforeBuildCommand": "npm run sync:web-dist",
    "frontendDist": "../web-dist"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
